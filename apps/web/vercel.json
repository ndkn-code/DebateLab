{
  "regions": ["sin1"],
  "functions": {
    "src/app/api/queues/practice-analysis/route.ts": {
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "practice-analysis",
          "retryAfterSeconds": 60,
          "initialDelaySeconds": 0
        }
      ]
    }
  },
  "crons": [
    {
      "path": "/api/cron/smart-popups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/email-dispatch",
      "schedule": "0 2 * * *"
    }
  ]
}
