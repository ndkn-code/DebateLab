# DebateLab Environment Variables
# Copy this file to .env.local and fill in your API keys

# Supabase Configuration
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Expo mobile public configuration.
# These values are safe to expose to the client. Do not add server secrets with
# EXPO_PUBLIC_ prefixes.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Fallback for projects still using legacy anon keys.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-google-ios-client-id
# Local-only Phase 3 simulator design QA. Keep blank outside development.
EXPO_PUBLIC_ENABLE_MOBILE_DESIGN_PREVIEW=
EXPO_PUBLIC_MOBILE_DESIGN_PREVIEW_ROUTE=today

# Secures /api/cron/smart-popups. Must match the Vercel Cron Authorization bearer token.
CRON_SECRET=replace-with-a-long-random-secret

# Set to false to temporarily disable in-app smart feature popup eligibility.
SMART_POPUPS_ENABLED=true

# 1v1 Duel ("debate-duel") launch switch. Leave unset/false to keep the feature
# admin-only (for shadow-testing the hidden ELO); set true to launch it for all
# users. NEXT_PUBLIC_ flips both the page/API gates and the sidebar nav entry.
NEXT_PUBLIC_DUEL_ENABLED=false

# Secret for the no-client duel judging handoff: pg_net (the duel-judging-dispatch
# cron) calls /api/debate-duels/[shareCode]/judge with this as a Bearer token when
# both players have disconnected at the judging step. Must match the Supabase Vault
# secret `duel_watchdog_secret`. Falls back to CRON_SECRET if unset.
#   In Supabase SQL (deploy-time):
#     select vault.create_secret('https://your-app-url', 'duel_judge_endpoint');
#     select vault.create_secret('<this value>',          'duel_watchdog_secret');
DUEL_WATCHDOG_SECRET=replace-with-a-long-random-secret

# Google Gemini API Key (for AI debate feedback)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for debate analysis (optional, defaults to gemini-2.5-flash)
# Supported: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API Key (for staged AI debate rebuttals and judging)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Server-side AI provider routing. Keep Gemini as fallback during rollout.
# Supported values: gemini, deepseek
DEBATE_AI_REBUTTAL_PROVIDER=gemini
DEBATE_AI_FEEDBACK_PROVIDER=gemini
DEBATE_DUEL_JUDGE_PROVIDER=gemini
SPEAKING_AI_FEEDBACK_PROVIDER=gemini
# Optional DeepSeek analysis knobs. Repair passes add latency; Gemini fallback is opt-in for sync analysis.
DEEPSEEK_ENABLE_FEEDBACK_REPAIR=false
DEEPSEEK_ANALYSIS_FALLBACK=

# Phase 2A debate corpus/RAG. Provider/model/dimensions/threshold defaults live
# in code. Keep AI_CORPUS_RAG_ENABLED=false until QA proves retrieval improves
# Vietnamese rebuttal/judging quality.
AI_CORPUS_RAG_ENABLED=false
AI_CORPUS_RAG_REVIEW_STATUSES=candidate,approved,needs_review
# Optional override for a different self-hosted embedding endpoint. The default
# is Thinkfy's Hugging Face Space.
DEBATE_CORPUS_EMBEDDING_URL=
DEBATE_CORPUS_EMBEDDING_API_KEY=
DEBATE_CORPUS_EMBEDDING_BEARER_TOKEN=
# Optional local/script-only fallback for one-off Voyage embedding jobs.
VOYAGE_API_KEY=your_voyage_api_key_here

# Deepgram API Key (for real-time speech-to-text)
# Get yours at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq API Key (for Vietnamese final STT refinement and coach chat)
GROQ_API_KEY=your_groq_api_key_here
# Optional emergency kill switch for post-speech Groq/Deepgram consensus.
STT_FINAL_RETRANSCRIBE_ENABLED=true
# Judge transcript repair is shadow-only by default. Keep USE_FOR_JUDGE=false
# until admin QA gates pass.
STT_JUDGE_TRANSCRIPT_REPAIR_SHADOW_ENABLED=true
STT_JUDGE_TRANSCRIPT_REPAIR_USE_FOR_JUDGE=false
STT_REPAIR_LANGUAGES=vi
STT_REPAIR_TRACKS=debate
STT_REPAIR_TIMEOUT_MS=8000
STT_REPAIR_MODEL=

# Azure Speech TTS (Vietnamese fallback voices)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=southeastasia

# Google Cloud Text-to-Speech (Vietnamese Standard, WaveNet, Neural2, Chirp 3 HD voices)
# Vercel/serverless: paste minified service account JSON into GOOGLE_TTS_SERVICE_ACCOUNT_JSON.
# Local: either set GOOGLE_TTS_SERVICE_ACCOUNT_JSON or point GOOGLE_APPLICATION_CREDENTIALS at the JSON file.
GOOGLE_TTS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_APPLICATION_CREDENTIALS=/secure/google-tts-service-account.json

# Local-only Browser QA helper. Never set these in production.
# Use /api/dev/auth-bypass?strategy=cookie for local QA without a real account.
DEV_AUTH_EMAIL=local-test-user@example.com
DEV_AUTH_PASSWORD=local-test-password

# Resend email delivery
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Default sender for Resend MCP and app email delivery. Must use a verified Resend domain.
SENDER_EMAIL_ADDRESS="Thinkfy <hello@thinkfy.net>"

# Optional reply-to address(es), comma-separated.
REPLY_TO_EMAIL_ADDRESSES=support@thinkfy.net

# Public app URL used in email CTA links and webhook setup.
NEXT_PUBLIC_APP_URL=https://thinkfy.net

# Embedded Tally issue report form. The form URL is public; the signing secret
# must match the secret configured in Tally's Webhooks integration.
NEXT_PUBLIC_TALLY_BUG_REPORT_FORM_URL=https://tally.so/embed/ODolq7
NEXT_PUBLIC_TALLY_BUG_REPORT_FORM_URL_VI=https://tally.so/embed/NpRXRQ
TALLY_BUG_REPORT_FORM_IDS=ODolq7,NpRXRQ
TALLY_WEBHOOK_SIGNING_SECRET=whsec_your_tally_webhook_secret_here

# Set false to keep email eligibility/auditing code available while preventing sends.
EMAILS_ENABLED=true

# Set true locally so dispatch audits candidates without sending through Resend.
EMAILS_DRY_RUN=true

# Optional: route every outgoing email to a test inbox while preserving the intended recipient in metadata.
EMAIL_TEST_RECIPIENT=

# Resend webhook signing secret from the webhook settings page.
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# Signing secret for visible and one-click unsubscribe links.
EMAIL_UNSUBSCRIBE_SECRET=replace_with_a_long_random_secret

# Beta access flag
# Defaults to true in code. Set to false to enforce premium/enterprise subscription gates.
BETA_ALL_ACCESS=true

# Profile social launch flags.
# Defaults to true in code after the privacy/RLS rollout. Set any value to false
# to temporarily disable that layer without removing the implementation.
NEXT_PUBLIC_PROFILE_SOCIAL_ENABLED=true
NEXT_PUBLIC_PROFILE_PUBLIC_READS_ENABLED=true
NEXT_PUBLIC_PROFILE_CONNECTIONS_ENABLED=true
NEXT_PUBLIC_PROFILE_DISCOVERY_ENABLED=true
NEXT_PUBLIC_PROFILE_FRIEND_CODES_ENABLED=true
NEXT_PUBLIC_PROFILE_SOCIAL_GUARDRAILS_ENABLED=true

# Local admin QA only. Ignored in production unless NODE_ENV is not production.
DEV_ADMIN_BYPASS=false
