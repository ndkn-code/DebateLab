# DebateLab Environment Variables
# Copy this file to .env.local and fill in your API keys

# Google Gemini API Key (for AI debate feedback)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for debate analysis (optional, defaults to gemini-2.5-flash)
# Supported: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Deepgram API Key (for real-time speech-to-text)
# Get yours at: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
